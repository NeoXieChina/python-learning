def primeFinder(startNumber,endNumber):
    if startNumber > endNmuber:
        return
    else:
        totalCount =0
        primeList = []
        for n in range(startNumber,endNumber+1):
            for i in range(startNumber,n):
                if n%i == 0:
                    break
            else:
                totalCount +=1
                primeList.append(n)
        return [primeList,totalCount]
print("其中素数有：",primeFinder(2,100)[0],",一共",primeFinder(2,100)[1],"个。")


def prime(Number):
    for i in range(2,Number):
        if Number%i ==0 :
            return False
    else:
        return True
for i in range(2,100+1):
    if prime(i) == True:
        print("{:^4}".format(i),end = " ")





def twinPrime(startNumber,endNmuber):
    if startNumber > endNmuber:
        return
    else:
        primeList = primeFinder(startNumber,endNmuber)[0]
        totalCount =0
        twinPrimeList = []
        for prime in range(len(primeList)):
            if (abs((primeList[prime] - primeList[prime-1])) == 2):
                twinPrimeList.append((primeList[prime-1],primeList[prime]))
                totalCount += 1
        return [twinPrimeList,totalCount]
print("其中孪生素数有：",twinPrime(2,100)[0],",一共",twinPrime(2,100)[1],"对。")


for i in range(2,100+1):
    if prime(i) == True and prime(i+2) == True:
        print("{:^4},{:^4}".format(i,i+2),end = "|")





def divideEven(startNumber,endNmuber):
    if startNumber > endNmuber:
        return
    else:
        if( startNumber % 2 == 1 ):
            startNumber += 1
        evenList = [evenNumber for evenNumber in range(startNumber,endNmuber+1,2)]
        primeList = primeFinder(2,endNmuber)[0]
        print(primeList)
        dividedList = []
        for item in evenList:
            for i in range(-len(primeList),0):
                if ((item - primeList[abs(i)-1]) in primeList):
                    dividedList.append(str(item)+"="+str(primeList[abs(i)-1])+"+"+str((item - primeList[abs(i)-1])))
                    break
        return dividedList
