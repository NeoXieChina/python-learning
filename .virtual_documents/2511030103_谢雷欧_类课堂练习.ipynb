


class Book():
    """Define a Book class"""
    name = ""
    author = ""
    isbn = ""
    price = 0
    publisher = ""
    def __init__(self, name:str,author:str,isbn:str,publisher:str,price:float):
        """Init the properties
        Args:
            name (string): [Book's name]
            author (string): [Book's author]
            isbn (string): [Book's isbn]
            price (float): [Book's price]
            publisher (str, optional): [description]. Defaults to "ABC Press".
        """
        self.name = name
        self.author = author
        self.isbn = isbn
        self.price = price
        self.publisher = publisher

    def info(self):
        print(f"The book's name:{self.name};\nThe book's author:{self.author};\nThe book's publisher:{self.publisher};\nThe book's isbn:{self.isbn};\nThe book's price:{self.price};\n\n")
help(Book)





bookNew =Book('hello','world','123456','xcxy','1.1')
Book.info(bookNew)


















