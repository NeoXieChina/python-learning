import random,math
a = random.randint(1,100)
b = random.randint(1,100)
c = random.randint(1,100)
gcd = 1
lcm = 1
print("系统生成的数是a={},b={},c={}。".format(a,b,c))
first,second,third = a,b,c
while(1):
    if first>second>third:
        break
    else:
        if first == max(first,second,third):
            if second == min(first,second,third):
                first,second,third = first,third,second
            else:
                first,second,third = first,second,third
        elif second == max(first,second,third):
            if first == min(first,second,third):
                first,second,third = second,third,first
            else:
                first,second,third = second,first,third
        elif third == max(first,second,third):
            if first == min(first,second,third):
                first,second,third = third,second,first
            else:
                first,second,third = third,first,second
for i in range(first,0,-1):
    if a%i ==0 and b%i ==0 and c%i ==0:
        gcdNum = i
        break
for i in range(third,first*second*third+1):
    if i%first ==0 and i%second ==0 and i%third ==0:
        lcmNum = i
        break
print("最大公约数是",gcdNum,math.gcd(a,b,c),"最小公倍数是",lcmNum,math.lcm(a,b,c))





